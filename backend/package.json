{
  "name": "filadelfia-whatsapp-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend minimo para automacao oficial de WhatsApp da Igreja Missionaria Filadelfia.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "bot:dev": "tsx src/bot.ts",
    "bot:start": "node dist/src/bot.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "baileys": "^7.0.0-rc13",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
